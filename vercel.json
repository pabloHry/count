{
  "functions": {
    "src/app/api/countdown-gif/route.ts": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/countdown-gif",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
